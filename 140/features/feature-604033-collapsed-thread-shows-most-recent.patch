# Parent  092ed407578c38d9a9d64722fa3988293563468d
Feature: Introduce pref mailnews.collapse_thread_to_most_recent and show most recent child in collapsed thread root. (Bug 604033)

diff --git a/mailnews/base/src/nsMsgDBView.cpp b/mailnews/base/src/nsMsgDBView.cpp
--- a/mailnews/base/src/nsMsgDBView.cpp
+++ b/mailnews/base/src/nsMsgDBView.cpp
@@ -2123,8 +2123,10 @@ nsMsgDBView::Open(nsIMsgFolder* folder, 
                   nsMsgViewFlagsTypeValue viewFlags) {
   AUTO_PROFILER_LABEL("nsMsgDBView::Open", MAILNEWS);
   mReversedThreading =
       mozilla::Preferences::GetBool("mailnews.reversed_threading", false);
+  mCollapseToMostRecent = mozilla::Preferences::GetBool(
+      "mailnews.collapse_thread_to_most_recent", false);
   m_viewFlags = viewFlags;
   m_sortOrder = sortOrder;
   m_sortType = sortType;
   m_folderFlags = 0;
@@ -4775,8 +4777,19 @@ nsresult nsMsgDBView::ExpandByIndex(nsMs
   nsCOMPtr<nsIMsgDBHdr> msgHdr;
   nsCOMPtr<nsIMsgThread> pThread;
   nsresult rv = GetThreadContainingIndex(index, getter_AddRefs(pThread));
   NS_ENSURE_SUCCESS(rv, rv);
+  if (CollapseToMostRecent()) {
+    // Restore damaged thead root.
+    pThread->GetChildKeyAt(0, &m_keys[index]);
+    pThread->GetChildHdrAt(0, getter_AddRefs(msgHdr));
+    uint32_t orgFlags;
+    msgHdr->GetFlags(&orgFlags);
+    flags = orgFlags |
+            (flags & (MSG_VIEW_FLAG_ISTHREAD | MSG_VIEW_FLAG_HASCHILDREN));
+    m_flags[index] = flags;
+    m_levels[index] = 0;
+  }
   if (m_viewFlags & nsMsgViewFlagsType::kUnreadOnly) {
     rv = ListUnreadIdsInThread(pThread, index, &numExpanded);
   } else {
     rv = ListIdsInThread(pThread, index, &numExpanded);
@@ -4851,8 +4864,55 @@ nsresult nsMsgDBView::CollapseByIndex(ns
 
   m_flags[index] = flags;
   int32_t numRemoved = -rowDelta;
 
+  if (CollapseToMostRecent()) {
+    // Make the root display the most recent child.
+    nsCOMPtr<nsIMsgThread> pThread;
+    nsresult rv = GetThreadContainingIndex(index, getter_AddRefs(pThread));
+    NS_ENSURE_SUCCESS(rv, rv);
+    uint32_t newestDate = 0;
+    uint32_t numChildren;
+    nsMsgKey newestKey = nsMsgKey_None;
+
+    pThread->GetNumChildren(&numChildren);
+    for (uint32_t childIndex = 0; childIndex < numChildren; childIndex++) {
+      nsCOMPtr<nsIMsgDBHdr> child;
+      rv = pThread->GetChildHdrAt(childIndex, getter_AddRefs(child));
+      if (NS_SUCCEEDED(rv)) {
+        uint32_t msgDate;
+        child->GetDateInSeconds(&msgDate);
+        if (msgDate > newestDate) {
+          newestDate = msgDate;
+          child->GetMessageKey(&newestKey);
+        }
+      }
+    }
+
+    if (newestKey != nsMsgKey_None) {
+      // Find index.
+      uint32_t newestIndex;
+      if (ReversedThreading()) {
+        // Start looking at the last child of the thread which is at the
+        // top in reversed threading. Likely it's already the one we want.
+        newestIndex = index - numRemoved;
+        newestIndex = m_keys.IndexOf(newestKey, newestIndex);
+      } else {
+        // Start looking at the last child of the thread which is at the
+        // bottom in reversed threading. Likely it's already the one we want.
+        newestIndex = index + numRemoved;
+        newestIndex = m_keys.LastIndexOf(newestKey, newestIndex);
+      }
+      m_keys[index] = m_keys[newestIndex];
+      m_flags[index] = m_flags[newestIndex];
+
+      // Carry over the relevant flags from the root.
+      m_flags[index] |= nsMsgMessageFlags::Elided;
+      m_flags[index] |=
+          (flags & (MSG_VIEW_FLAG_ISTHREAD | MSG_VIEW_FLAG_HASCHILDREN));
+    }
+  }
+
   if (ReversedThreading()) {
     // Remove rows above `index`.
     if (index < (nsMsgViewIndex)numRemoved) {
       NS_ERROR("trying to remove too many rows");
@@ -6966,8 +7026,9 @@ nsresult nsMsgDBView::CopyDBView(nsMsgDB
   aNewMsgDBView->m_viewFlags = m_viewFlags;
   aNewMsgDBView->m_sortOrder = m_sortOrder;
   aNewMsgDBView->m_sortType = m_sortType;
   aNewMsgDBView->mReversedThreading = mReversedThreading;
+  aNewMsgDBView->mCollapseToMostRecent = mCollapseToMostRecent;
   aNewMsgDBView->m_curCustomColumn = m_curCustomColumn;
   aNewMsgDBView->m_secondarySort = m_secondarySort;
   aNewMsgDBView->m_secondarySortOrder = m_secondarySortOrder;
   aNewMsgDBView->m_secondaryCustomColumn = m_secondaryCustomColumn;
diff --git a/mailnews/base/src/nsMsgDBView.h b/mailnews/base/src/nsMsgDBView.h
--- a/mailnews/base/src/nsMsgDBView.h
+++ b/mailnews/base/src/nsMsgDBView.h
@@ -504,8 +504,15 @@ class nsMsgDBView : public nsIMsgDBView,
            !(m_viewFlags & nsMsgViewFlagsType::kGroupBySort) &&
            m_sortType == nsMsgViewSortType::byDate &&
            m_sortOrder == nsMsgViewSortOrder::descending;
   }
+  bool mCollapseToMostRecent;
+  inline bool CollapseToMostRecent() {
+    return mCollapseToMostRecent &&
+           m_viewFlags & nsMsgViewFlagsType::kThreadedDisplay &&
+           !(m_viewFlags & nsMsgViewFlagsType::kGroupBySort) &&
+           m_sortType == nsMsgViewSortType::byDate;
+  }
 
  protected:
   static nsresult InitDisplayFormats();
 
diff --git a/mailnews/base/src/nsMsgThreadedDBView.cpp b/mailnews/base/src/nsMsgThreadedDBView.cpp
--- a/mailnews/base/src/nsMsgThreadedDBView.cpp
+++ b/mailnews/base/src/nsMsgThreadedDBView.cpp
@@ -177,8 +177,38 @@ nsresult nsMsgThreadedDBView::InitThread
     if ((!(m_viewFlags & nsMsgViewFlagsType::kThreadedDisplay) ||
          m_viewFlags & nsMsgViewFlagsType::kExpandAll) &&
         msgFlags & nsMsgMessageFlags::Elided) {
       ExpandByIndex(m_keys.Length() - 1, nullptr);
+    } else if (CollapseToMostRecent()) {
+      // We need to replace the unexpanded root with the most recent child.
+      // Mostly copied from nsMsgDBView::CollapseByIndex().
+      uint32_t newestDate = 0;
+      nsMsgKey newestKey = nsMsgKey_None;
+      nsCOMPtr<nsIMsgDBHdr> newestChild;
+
+      for (uint32_t childIndex = 0; childIndex < numChildren; childIndex++) {
+        nsCOMPtr<nsIMsgDBHdr> child;
+        rv = threadHdr->GetChildHdrAt(childIndex, getter_AddRefs(child));
+        if (NS_SUCCEEDED(rv)) {
+          uint32_t msgDate;
+          child->GetDateInSeconds(&msgDate);
+          if (msgDate > newestDate) {
+            newestDate = msgDate;
+            child->GetMessageKey(&newestKey);
+            newestChild = child;
+          }
+        }
+      }
+      if (newestKey != nsMsgKey_None) {
+        uint32_t lastIndex = m_keys.Length() - 1;
+        m_keys[lastIndex] = newestKey;
+        newestChild->GetFlags(&m_flags[lastIndex]);
+
+        // Carry over the relevant flags from the root.
+        m_flags[lastIndex] |= nsMsgMessageFlags::Elided;
+        m_flags[lastIndex] |=
+            (msgFlags & (MSG_VIEW_FLAG_ISTHREAD | MSG_VIEW_FLAG_HASCHILDREN));
+      }
     }
 
     count++;
   }
