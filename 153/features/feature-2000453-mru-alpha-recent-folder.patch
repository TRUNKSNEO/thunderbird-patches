# HG changeset patch
# User Betterbird <betterbird@betterbird.eu>
# Date 1778792038 -7200
# Parent  09be63192324e8bb674ee7da3c88a7105af47d91
Feature: Follow-up to bug 2000453: Add combination of MRU and alphabetic for recent folders.

Based on the original idea in https://phabricator.services.mozilla.com/D277216 which wasn't accepted by the TB folks as they preferred a dumber solution.
Betterbird already shipped this solution in version 140.

diff --git a/mail/components/preferences/general.inc.xhtml b/mail/components/preferences/general.inc.xhtml
--- a/mail/components/preferences/general.inc.xhtml
+++ b/mail/components/preferences/general.inc.xhtml
@@ -782,10 +782,11 @@
       <hbox align="center" pack="start">
         <label control="recentSortOrder" data-l10n-id="recent-sort-order-label"/>
         <menulist id="recentSortOrder" preference="mail.folder_widget.recent_sort_order">
           <menupopup>
+            <menuitem data-l10n-id="recent-sort-order-combined" value="2"/>
+            <menuitem data-l10n-id="recent-sort-order-alphabetic" value="1"/>
             <menuitem data-l10n-id="recent-sort-order-mru" value="0"/>
-            <menuitem data-l10n-id="recent-sort-order-alphabetic" value="1"/>
           </menupopup>
         </menulist>
       </hbox>
 
